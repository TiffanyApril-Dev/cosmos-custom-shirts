DJANGO_SECRET_KEY=replace-with-a-long-random-value
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=shirts.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://shirts.example.com
DJANGO_SECURE_SSL=True
DJANGO_DEMO_MODE=True

# Only needed when DJANGO_DEMO_MODE=False and email delivery is enabled.
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=email-smtp.us-east-1.amazonaws.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=True
DJANGO_DEFAULT_FROM_EMAIL=Cosmos Demo <noreply@example.com>

# Optional persistent production paths. Local development uses project folders.
DJANGO_DATABASE_PATH=/var/lib/cosmos/data/db.sqlite3
DJANGO_MEDIA_ROOT=/var/lib/cosmos/media
DJANGO_STATIC_ROOT=/var/lib/cosmos/static
